{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "run_build (기본)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/cache_rag-poc-type2/scripts/run_build.py",
      "python": "${workspaceFolder}/cache_rag-poc-type2/venv/Scripts/python.exe",
      "args": [],
      "cwd": "${workspaceFolder}/cache_rag-poc-type2",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/cache_rag-poc-type2/src"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
